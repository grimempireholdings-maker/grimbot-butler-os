GRIMBOT_MOCK_PERCEPTION=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GRIMBOT_DB_PATH=memory/grimbot_brain.sqlite3
GRIMBOT_IMAGE_DIR=vision/images
GRIMBOT_VOICE_MOCK=true
GRIMBOT_AUDIO_DIR=voice/audio
GRIMBOT_CONVERSATION_PROVIDER=mock
GRIMBOT_CONVERSATION_TIMEOUT_SECONDS=20
GRIMBOT_CONVERSATION_MAX_TOKENS=900
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_SITE_URL=
TAVILY_API_KEY=
GRIMBOT_WEATHER_LOCATION=Dayton, Ohio
# Pin a fast non-reasoning model for the 3-second classification call (independent of OPENROUTER_MODEL)
# Recommended: meta-llama/llama-3.1-8b-instruct:free (free tier) or openai/gpt-4o-mini
GRIMBOT_CONVERSATION_CLASSIFIER_MODEL=
GRIMBOT_CONVERSATION_CLAUDE_MODEL=claude-3-5-sonnet-latest
GRIMBOT_CONVERSATION_OPENAI_MODEL=gpt-4.1-mini
GRIMBOT_CONVERSATION_GEMINI_MODEL=gemini-1.5-flash
GRIMBOT_HOST=127.0.0.1
GRIMBOT_PORT=8000
